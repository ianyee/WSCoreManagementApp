rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'SuperAdmin';
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role in ['SuperAdmin', 'Admin'];
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ─── users/{uid} ─────────────────────────────────────────────────────────
    // Users can read their own profile.
    // SuperAdmin (via Cloud Functions with Admin SDK) manages all create/update/delete.
    // Client-side writes limited: owner may update non-sensitive fields only.

    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin()
        || (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'createdAt', 'uid']));
      allow delete: if isSuperAdmin();
    }

    // ─── userPermissions/{uid} ───────────────────────────────────────────────
    // Permissions doc holds role + domain access.
    // Only SuperAdmin (or Cloud Functions using Admin SDK) may write.
    // Each user may read their own permissions doc (for UI display).

    match /userPermissions/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isSuperAdmin();
    }

    // ─── auditLog/{entry} ────────────────────────────────────────────────────
    // Written by Cloud Functions (Admin SDK) only. SuperAdmin may read.
    // TTL-managed: documents auto-expire after 90 days via expireAt field.
    match /auditLog/{entry} {
      allow read:  if isSuperAdmin();
      allow write: if false;
    }

    // ─── app_domains/{domainKey} ─────────────────────────────────────────────
    // All authenticated users may read (needed for app launcher + user modal).
    // Only SuperAdmin may write.
    match /app_domains/{domainKey} {
      allow read:  if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ─── clients/{clientId} ──────────────────────────────────────────────────
    // Shared client registry used by all Workscale apps.
    // All signed-in users may read (needed by child app pickers).
    // Admin and SuperAdmin may create/update. No client deletion allowed.
    match /clients/{clientId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── counters/{counterId} ────────────────────────────────────────────────
    // Sequence counters for auto-generated IDs (e.g. C-XXXX for clients).
    // Admin and SuperAdmin may read/write via transactions.
    match /counters/{counterId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ─── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

