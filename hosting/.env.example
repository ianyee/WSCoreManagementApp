# .env.local  ← copy this file and name it .env.local, never commit secrets

VITE_APP_NAME=My App

# Your Firebase project config (from Firebase Console → Project Settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated list of allowed email domains (leave blank to allow any Microsoft account)
# Example: mycompany.com,partner.com
VITE_ALLOWED_EMAIL_DOMAINS=
