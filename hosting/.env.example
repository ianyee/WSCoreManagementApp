# Copy this file to .env.local and fill in the values. Never commit secrets.

# ─── Firebase App Config (from Firebase Console → Project Settings) ──────────
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=workscale-core.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=workscale-core
VITE_FIREBASE_STORAGE_BUCKET=workscale-core.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ─── SSO Cloud Function URLs (asia-southeast1) ───────────────────────────────
VITE_CREATE_SESSION_URL=https://asia-southeast1-workscale-core.cloudfunctions.net/createSessionCookie
VITE_REVOKE_SESSION_URL=https://asia-southeast1-workscale-core.cloudfunctions.net/revokeSession

# ─── Microsoft Entra ID (Azure AD) ───────────────────────────────────────────
# Directory (tenant) ID from your Azure App Registration.
# Setting this locks sign-in to the workscale.ph org only.
VITE_MICROSOFT_TENANT_ID=your-azure-tenant-id

# ─── Notes for downstream apps consuming this SSO ────────────────────────────
# Call verifySessionCookie to validate the HTTP-only __session cookie:
# GET https://asia-southeast1-workscale-core.cloudfunctions.net/verifySessionCookie
# Returns: { uid, email, role, domains, sso: true }
